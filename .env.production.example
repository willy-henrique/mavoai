# ============================================================
# MAVO AI — Variáveis de Produção
# Copie este arquivo para .env.production e preencha os valores
# NUNCA suba .env.production para o git!
# ============================================================

# URL pública do servidor (IP fixo ou domínio)
# Ex: http://200.100.50.25:3000  ou  https://mavo.suaempresa.com.br
NEXT_PUBLIC_BASE_URL=http://SEU_IP_AQUI:3000
INTERNAL_BASE_URL=http://localhost:3000

# ── BANCO DE DADOS ───────────────────────────────────────────
# Docker: usa nome do serviço "postgres" como host
DATABASE_URL=postgresql://postgres:SENHA_FORTE_AQUI@postgres:5432/mavoai
# PM2 (conexão direta): usar localhost
# DATABASE_URL=postgresql://postgres:SENHA_FORTE_AQUI@localhost:6001/mavoai
POSTGRES_PASSWORD=SENHA_FORTE_AQUI

# ── IA — GROQ (grátis: 14.400 req/dia) ──────────────────────
# Criar chave em: https://console.groq.com/keys
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=gsk_SUA_CHAVE_GROQ_AQUI
GROQ_API_KEY=gsk_SUA_CHAVE_GROQ_AQUI
AI_CHAT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AI_CURATOR_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct

# ── EMBEDDINGS — JINA AI (grátis: 1M tokens/mês) ────────────
# Criar chave em: https://jina.ai/embeddings
EMBEDDING_BASE_URL=https://api.jina.ai/v1
EMBEDDING_API_KEY=jina_SUA_CHAVE_JINA_AQUI
AI_EMBEDDING_MODEL=jina-embeddings-v5-text-small
AI_EMBEDDING_DIMENSIONS=1024
AI_EMBEDDING_TASK=retrieval.passage

# ── SUPABASE (autenticação, opcional) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── MTALK INTEGRATION ────────────────────────────────────────
MTALK_BASE_URL=https://s11.mtalk.com.br
MTALK_API_TOKEN=SEU_TOKEN_MTALK
MTALK_ACCOUNT_ID=1
MTALK_AUTO_REPLY_ENABLED=true
MTALK_ADMIN_EMAIL=admin@suaempresa.com
MTALK_ADMIN_PASS=SENHA_MTALK

# ── SEGURANÇA ────────────────────────────────────────────────
CEREBRO_INGEST_TOKEN=GERAR_TOKEN_ALEATORIO_AQUI
CEREBRO_INTERNAL_TOKEN=GERAR_TOKEN_ALEATORIO_AQUI
API_RATE_LIMIT_PER_MINUTE=60
INTEGRATION_AUTH_REQUIRED=true

# ── OPCIONAIS ────────────────────────────────────────────────
ENABLE_AI_ROUTER=true
OPENROUTER_API_KEY=sk-or-v1-...
GOOGLE_API_KEY=AIza...
