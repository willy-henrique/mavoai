NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL local via docker compose / pgvector
# Porta 5434 = Docker mapeado (5434:5432). PostgreSQL nativo local: 5432.
DATABASE_URL=postgresql://postgres:1@localhost:5434/mavoai

# Chat IA (OpenAI-compatible: Groq, xAI, OpenAI)
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=sua_chave_aqui
# Opcional: GROQ_API_KEY= (alias da chave Groq gsk_...)
# Com Groq e sem AI_CHAT_MODEL, o Cérebro usa Llama 4 Scout (texto + visão no orquestrador):
#   meta-llama/llama-4-scout-17b-16e-instruct
AI_CHAT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Embeddings — use qualquer API compatível com OpenAI:
#   Jina AI (grátis 1M tokens): https://jina.ai  → EMBEDDING_BASE_URL=https://api.jina.ai/v1
#   OpenAI: EMBEDDING_BASE_URL=https://api.openai.com/v1
#   NAO use AI_API_KEY Groq (gsk_) aqui — Groq nao tem embeddings
EMBEDDING_BASE_URL=https://api.jina.ai/v1
EMBEDDING_API_KEY=
# Jina: jina-embeddings-v5-text-small | OpenAI: text-embedding-3-small
AI_EMBEDDING_MODEL=jina-embeddings-v5-text-small
# Dimensao do vetor — deve bater com o schema do banco (vector(1536))
# Jina: 1024 | OpenAI text-embedding-3-small: 1536
AI_EMBEDDING_DIMENSIONS=1024
# Task para modelos Jina/Matryoshka (ignorado pelo OpenAI)
# Import: retrieval.passage | Busca: retrieval.query (configurado automaticamente)
AI_EMBEDDING_TASK=retrieval.passage

# Opcional para chamadas internas server-to-server
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CEREBRO_INTERNAL_TOKEN=troque-por-outro-token-forte

# Entrada do WillTalk -> n8n
WILLTALK_WEBHOOK_URL=http://localhost:5678/webhook/willtalk-ingestao
WILLTALK_WEBHOOK_TOKEN=troque-por-um-token-forte
WILLTALK_WEBHOOK_EVENTS=ticket_created,ticket_updated,message_received,message_sent
WILLTALK_WEBHOOK_MAX_CHARS=12000
WILLTALK_WEBHOOK_ATTEMPTS=3
WILLTALK_WEBHOOK_TIMEOUT_MS=8000

# Saida opcional de resposta automatica para o WillTalk
WILLTALK_AUTO_REPLY_ENABLED=true
WILLTALK_REPLY_WEBHOOK_URL=http://localhost:4002/api/webhooks/cerebro/reply

# Orquestrador (triagem + menu + visao) — WillTalk/MTalk chamam este projeto
# Em producao, mantenha true e configure o mesmo Bearer no n8n/WillTalk.
INTEGRATION_AUTH_REQUIRED=true
CEREBRO_INGEST_TOKEN=troque-por-um-token-forte
INTEGRATION_RATE_LIMIT_PER_MIN=120
# Visão no orquestrador: com AI_BASE_URL Groq → mesma gsk_ + Scout (omitir ou igual ao chat).
# Só xAI: XAI_API_KEY + opcional VISION_API_BASE_URL=https://api.x.ai/v1
# Só OpenAI vision: VISION_API_BASE_URL=https://api.openai.com/v1 + OPENAI_API_KEY
XAI_API_KEY=
# WILLTALK_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# MTalk — conectar Mavo AI como bot respondedor
# MTALK_BASE_URL=https://s11.mtalk.com.br
# MTALK_API_TOKEN=         (Settings → Perfil → Token de Acesso)
# MTALK_ACCOUNT_ID=1       (ID da conta, ver na URL: /app/accounts/1/...)
# MTALK_AUTO_REPLY_ENABLED=true
# Quando MTALK_AUTO_REPLY_ENABLED=true, desabilite o WillTalk para nao duplicar:
# WILLTALK_AUTO_REPLY_ENABLED=false
