NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Chat IA (OpenAI-compatible: Groq, xAI, OpenAI)
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
# Opcional: GROQ_API_KEY= (alias da chave Groq gsk_...)
# Com Groq e sem AI_CHAT_MODEL, o Cérebro usa Llama 4 Scout (texto + visão no orquestrador):
#   meta-llama/llama-4-scout-17b-16e-instruct
AI_CHAT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Embeddings (OpenAI — NAO use AI_API_KEY Groq gsk_ aqui)
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
# ou: OPENAI_API_KEY=sk-...
AI_EMBEDDING_MODEL=text-embedding-3-small

# Opcional para chamadas internas server-to-server
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Entrada do WillTalk -> n8n
WILLTALK_WEBHOOK_URL=http://localhost:5678/webhook/willtalk-ingestao
WILLTALK_WEBHOOK_TOKEN=troque-por-um-token-forte
WILLTALK_WEBHOOK_EVENTS=ticket_created,ticket_updated,message_received,message_sent
WILLTALK_WEBHOOK_MAX_CHARS=12000
WILLTALK_WEBHOOK_ATTEMPTS=3
WILLTALK_WEBHOOK_TIMEOUT_MS=8000

# Saida opcional de resposta automatica para o WillTalk
WILLTALK_AUTO_REPLY_ENABLED=true
WILLTALK_REPLY_WEBHOOK_URL=http://localhost:4002/api/webhooks/cerebro/reply

# Orquestrador (triagem + menu + visao) — WillTalk/MTalk chamam este projeto
# Em producao, mantenha true e configure o mesmo Bearer no n8n/WillTalk.
INTEGRATION_AUTH_REQUIRED=true
CEREBRO_INGEST_TOKEN=troque-por-um-token-forte
# Visão no orquestrador: com AI_BASE_URL Groq → mesma gsk_ + Scout (omitir ou igual ao chat).
# Só xAI: XAI_API_KEY + opcional VISION_API_BASE_URL=https://api.x.ai/v1
# Só OpenAI vision: VISION_API_BASE_URL=https://api.openai.com/v1 + OPENAI_API_KEY
XAI_API_KEY=
# WILLTALK_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
