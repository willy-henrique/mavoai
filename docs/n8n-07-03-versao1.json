    },
    {
      "parameters": {
        "jsCode": "const origem = $input.first().json || {};\nreturn [{ json: { status: 'erro', etapa: 'pipeline', erro: origem.error || origem.message || 'falha_na_integracao', detalhe: origem, ticket_id: $('2. Normalizar Dados').item.json.ticket_id || null, timestamp: new Date().toISOString() } }];"
      },
      "id": "node_tratar_erro",
