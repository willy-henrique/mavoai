        "url": "={{ $env.WILLTALK_REPLY_URL || 'http://localhost:4002/api/webhooks/cerebro/reply' }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ ticket_id: $('2. Normalizar Dados').item.json.ticket_id, cliente: $('2. Normalizar Dados').item.json.cliente, canal: $('2. Normalizar Dados').item.json.canal, resposta_sugerida: $json.resposta_sugerida, origem: 'cerebro-operacional', data_evento: new Date().toISOString() }) }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + ($env.WILLTALK_TOKEN || '9e24439a849860fd74f93190df8b5ebb8c2bc7922beceba5020b8a335f45e3e1') }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {
