    {
      "parameters": {
        "jsCode": "const r = $json || {};\nconst confianca = String(r.confianca || '').toLowerCase();\nconst resposta = String(r.resposta_sugerida || '').trim();\nconst enviar = resposta.length > 0 && (confianca === 'alta' || confianca === 'media');\n\nreturn [{ json: { ...r, enviar_resposta: enviar, motivo: enviar ? 'confianca_suficiente' : 'confianca_baixa_ou_sem_resposta' } }];"
      },
      "id": "node_decidir_envio",
