              "value": "default"
            },
            {
              "name": "X-Ingestion-Id",
              "value": "={{ 'ing-' + Date.now() }}"
            }
          ]
        },
        "options": {
          "timeout": 12000
        }
      },
      "id": "node_ingestao",
      "name": "5. Ingestao MAVO.AI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
