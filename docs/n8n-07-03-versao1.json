        }
      },
      "id": "node_enviar_resposta",
      "name": "7. Enviar Resposta WillTalk",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2360, 120],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 2000,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { status: 'sucesso', etapa: 'pipeline_concluida', ticket_id: $('2. Normalizar Dados').item.json.ticket_id, atendimento_id: $('5.1 Ingestao OK?').item.json.atendimento_id || null, confianca: $('6.1 Decidir Envio').item.json.confianca || null, resposta_enviada: $('6.1 Decidir Envio').item.json.enviar_resposta || false, timestamp: new Date().toISOString() } }];"
      },
      "id": "node_log_sucesso",
      "name": "8. Log Sucesso",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2580, 120]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { status: 'triagem_pendente', motivo: 'triagemCompleted=false', ticket_id: $('2. Normalizar Dados').item.json.ticket_id, timestamp: new Date().toISOString() } }];"
      },
      "id": "node_log_triagem",
      "name": "9. Log Triagem Pendente",
