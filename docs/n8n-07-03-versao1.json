      },
      "id": "node_webhook",
      "name": "1. Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [220, 300]
    },
    {
      "parameters": {
        "jsCode": "const src = $json.body && typeof $json.body === 'object' ? { ...$json, ...$json.body } : $json;\n\nfunction toText(v) {\n  if (v == null) return '';\n  if (typeof v === 'string') return v;\n  if (Array.isArray(v)) return v.map(toText).join(' ');\n  if (typeof v === 'object') return toText(v.text || v.mensagem || v.content || '');\n  return String(v);\n}\n\nconst mensagem = toText(src.mensagem || src.mensagens || src.message || '').replace(/\\s+/g, ' ').trim();\nif (!mensagem) throw new Error('Mensagem vazia no payload');\n\nconst ticketId = String(src.ticket_id || src.ticket?.id || src.conversation_id || `WT-${Date.now()}`).trim();\nconst clienteNome = String(src.cliente || src.contact?.name || src.customer?.name || 'Cliente').trim();\nconst clienteTelefone = String(src.cliente_telefone || src.phone || src.contact?.phoneNumber || src.from || '').trim();\n\nreturn [{\n  json: {\n    ticket_id: ticketId,\n    cliente: clienteNome,\n    cliente_telefone: clienteTelefone,\n    mensagens: mensagem,\n    canal: src.canal || 'whatsapp',\n    tecnico: src.tecnico || 'n8n',\n    data_evento: src.data_evento || src.timestamp || new Date().toISOString(),\n    triageCompleted: Boolean(src.triageCompleted),\n    organization_id: src.organization_id || src.organizationId || null,\n    event_id: src.event_id || `evt-${Date.now()}`\n  }\n}];"
      },
      "id": "node_normalizar",
      "name": "2. Normalizar Dados",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WILLTALK_URL || 'http://localhost:4002' }}/api/webhooks/n8n/ticket-upsert",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ event_id: $json.event_id, canal: $json.canal, organization_id: $json.organization_id || undefined, cliente: { nome: $json.cliente, telefone: $json.cliente_telefone }, mensagem: $json.mensagens, ticket_id: $json.ticket_id }) }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + ($env.WILLTALK_TOKEN || '9e24439a849860fd74f93190df8b5ebb8c2bc7922beceba5020b8a335f45e3e1') }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {
          "timeout": 15000
        }
      },
      "id": "node_triagem_willtalk",
      "name": "3. Triagem WillTalk",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [730, 300],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 2000,
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.triageCompleted }}",
              "operation": "equal",
              "value2": true
            }
          ]
        },
        "options": {}
      },
      "id": "node_if_triagem",
      "name": "4. Triagem Completa?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.1,
      "position": [980, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.MAVOAI_URL || 'http://localhost:3000' }}/api/ingestao/willtalk",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ ticket_id: $('2. Normalizar Dados').item.json.ticket_id, cliente: $('2. Normalizar Dados').item.json.cliente, canal: $('2. Normalizar Dados').item.json.canal, mensagens: $('2. Normalizar Dados').item.json.mensagens, tecnico: $('2. Normalizar Dados').item.json.tecnico, data_evento: $('2. Normalizar Dados').item.json.data_evento }) }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + ($env.MAVOAI_TOKEN || '9e24439a849860fd74f93190df8b5ebb8c2bc7922beceba5020b8a335f45e3e1') }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "X-Source-System",
              "value": "willtalk"
            },
            {
              "name": "X-Source-Entity-Id",
              "value": "={{ $('2. Normalizar Dados').item.json.ticket_id }}"
            },
            {
